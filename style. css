body {
    margin: 0;
    font-family: Arial;
    background: #0d1117;
    color: white;
}

nav {
    display: flex;
    justify-content: space-between;
    padding: 15px;
    background: #161b22;
}

nav ul {
    display: flex;
    list-style: none;
}

nav ul li {
    margin: 0 10px;
}

nav a {
    color: white;
    text-decoration: none;
}

.home {
    text-align: center;
    padding: 80px;
}

.profile {
    width: 120px;
    border-radius: 50%;
}

span {
    color: cyan;
}

section {
    padding: 40px;
}

.box span {
    border: 1px solid cyan;
    padding: 8px;
    margin: 5px;
    display: inline-block;
}

.project {
    background: #161b22;
    padding: 15px;
    margin: 10px 0;
    border-radius: 10px;
}

#certificates img {
    width: 200px;
    margin: 10px;
}